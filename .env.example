# Teaching Monster AI - Environment Variables Template

# LLM API Keys
GOOGLE_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_kilo_xai_api_key_here
CARTESIA_API_KEY=your_cartesia_api_key_here

# Key Pools (for high-performance contest mode)
# GOOGLE_API_KEY_POOL=key1,key2,key3
# XAI_API_KEY_POOL=key1,key2,key3
# OPENROUTER_API_KEY_POOL=key1,key2,key3

# Search API (Optional)
SEARCH_API_KEY=your_search_api_key_here
SEARCH_CX=your_search_engine_id_here

# Pexels API (for MoneyPrinterTurbo-style background videos)
PEXELS_API_KEY=your_pexels_api_key_here

# Optional: Override ffmpeg binary path (default: auto-resolved from system PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg

# Model Configuration (Choose based on your API keys and needs)
# PRIMARY_MODEL=models/gemini-2.0-flash          # Default Gemini
# FALLBACK_MODEL=models/gemini-1.5-flash         # Gemini fallback
# PRIMARY_MODEL=xai/grok-beta                    # Free xAI (if XAI_API_KEY set)
# PRIMARY_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free  # Free OpenRouter

# Enable parallel processing in contest
# CONTEST_MODE=true

# ── NLM Studio Integration (v0.7.0) ─────────────────────────────────────────
# Set false to disable NLM and fall back to Gemini infographic + Cartesia TTS
NLM_SLIDES_ENABLED=true
NLM_AUDIO_ENABLED=true
NLM_SLIDE_TIMEOUT_S=480
NLM_AUDIO_TIMEOUT_S=600
NLM_QUIZ_TIMEOUT_S=300

# P4-B RLT Configuration
RLT_BLEND_WEIGHT=0.30
RLT_STUDENT_MODEL=google/gemini-2.0-flash-exp:free

# Server Configuration
PORT=8000
HOST=0.0.0.0
